# Fish Audio — TTS + клонирование голоса (замена ElevenLabs, без санкций)
# Получить: fish.audio → API Keys → Create API Key
FISH_AUDIO_API_KEY=your_fish_audio_key

# Hedra — lip-sync видео из фото
# Получить: app.hedra.com → API Keys
HEDRA_API_KEY=sk_hedra_xxxxx

# Claude API — тексты постов и идеи
# Получить: console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxx

# VEO3 — продление видео и B-roll (опционально)
VEO3_API_KEY=

# Auth
JWT_SECRET=change_me_to_random_string_min_32_chars

# Database
DATABASE_URL=jdbc:postgresql://localhost:5432/videoavataraii
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# RuStore Publisher API
RUSTORE_API_KEY=

# Push уведомления
FCM_SERVER_KEY=

# laozhang.ai — API прокси без санкций (GPT-5, Claude, Gemini, VEO3)
# Получить ключ: https://api.laozhang.ai/token
# Поддерживаемые модели: chatgpt-5.2, gpt-4o, claude-3-5-haiku, gemini-2.5-flash и др.
LAOZHANG_API_KEY=your_laozhang_key
LAOZHANG_MODEL=chatgpt-5.2
