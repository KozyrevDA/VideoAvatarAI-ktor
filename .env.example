# ── Hedra Platform API ─────────────────────────────────────────────────────────
# Получить: app.hedra.com → Settings → API Keys
HEDRA_API_KEY=your_hedra_api_key

# Модель аватара (менять не нужно — оставь как есть)
# Доступные модели и цены: app.hedra.com/pricing
#   kling_ai_avatar_v2_standard  — 8 кр/сек  ← ИСПОЛЬЗУЕМ (лучший баланс цена/качество)
#   kling_ai_avatar_v2_pro       — 24 кр/сек (в 3 раза дороже)
#   hedra_character_3            — 8 кр/сек  (старая модель)
#   hedra_avatar                 — 7 кр/сек  (самая дешёвая)
HEDRA_AVATAR_MODEL=kling_ai_avatar_v2_standard

# ── Fish Audio ─────────────────────────────────────────────────────────────────
# TTS + клонирование голоса (замена ElevenLabs, без санкций РФ)
# Получить: fish.audio → API Keys
FISH_AUDIO_API_KEY=your_fish_audio_key

# ── laozhang.ai ────────────────────────────────────────────────────────────────
# Тексты постов и 30 идей (GPT-5.2 через китайский прокси, без санкций)
# Получить: api.laozhang.ai/token
LAOZHANG_API_KEY=your_laozhang_key
LAOZHANG_MODEL=chatgpt-5.2

# ── Auth ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_random_string_min_32_chars

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=jdbc:postgresql://localhost:5432/videoavataraii
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# ── Push уведомления ───────────────────────────────────────────────────────────
# Firebase Console → Project Settings → Cloud Messaging
FCM_SERVER_KEY=your_fcm_server_key

# ── Billing ────────────────────────────────────────────────────────────────────
RUSTORE_API_KEY=your_rustore_key
GOOGLE_SERVICE_ACCOUNT_JSON=path_to_service_account.json

# ── Опционально ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
VEO3_API_KEY=
